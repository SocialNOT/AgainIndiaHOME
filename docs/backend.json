
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user birth details and calculated cosmic resonance data.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "birthTime": { "type": "string" },
        "birthPlace": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lon": { "type": "number" },
            "name": { "type": "string" }
          }
        },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "birthDate", "birthPlace"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Individual user settings and birth data."
    }
  }
}
