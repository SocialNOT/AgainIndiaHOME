
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user birth details and calculated cosmic resonance data.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "birthTime": { "type": "string" },
        "birthPlace": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lon": { "type": "number" },
            "name": { "type": "string" }
          }
        },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "birthDate", "birthPlace"]
    },
    "UserRitual": {
      "title": "User Ritual",
      "description": "A personalized daily micro-ritual assigned by Sankhya.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["color", "music", "action", "combined"] },
        "ritualActions": { "type": "array", "items": { "type": "string" } },
        "timestamp": { "type": "string", "format": "date-time" },
        "completed": { "type": "boolean" },
        "rationale": { "type": "string" }
      }
    },
    "UserAnalysis": {
      "title": "User Analysis",
      "description": "Saved Vastu or Palmistry analysis reports.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["palm", "vastu"] },
        "content": { "type": "string" },
        "remedies": { "type": "array", "items": { "type": "string" } },
        "balance": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" },
        "photoUrl": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Individual user settings and birth data."
    },
    "/users/{userId}/rituals/{ritualId}": {
      "schema": "UserRitual",
      "description": "Daily rituals assigned to the user."
    },
    "/users/{userId}/history/{analysisId}": {
      "schema": "UserAnalysis",
      "description": "Historical Vastu and Palmistry reports."
    }
  }
}
